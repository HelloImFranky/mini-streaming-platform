{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug api-gateway",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/api-gateway",
      "env": {
        "PORT": "8080",
        "USER_SERVICE_URL": "http://localhost:8081",
        "CONTENT_SERVICE_URL": "http://localhost:8082",
        "PLAYBACK_SERVICE_URL": "http://localhost:8083"
      },
      "args": [],
      "showLog": true
    },
    {
      "name": "Debug playback-service",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/playback-service",
      "env": {
        "PORT": "8083",
        "LATENCY_SPIKE_PCT": "0"
      },
      "args": [],
      "showLog": true
    },
    {
      "name": "Debug user-service (Python)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "8081", "--reload"],
      "jinja": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/services/user-service",
      "env": {
        "PORT": "8081"
      }
    },
    {
      "name": "Debug content-service (Python)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "8082", "--reload"],
      "jinja": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/services/content-service",
      "env": {
        "PORT": "8082",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug all Go services",
      "configurations": ["Debug api-gateway", "Debug playback-service"]
    }
  ]
}
